@model demo.Models.MeetingMemberModel

<div class="container">
    <h3>
        @(Model != null && Model.MeetingMemberId > 0
                ? "Edit Meeting Member"
                : "Add New Meeting Member")
    </h3>

    <div class="d-flex justify-content-center p-1">
        <div class="cardtable rounded-4">

            <header class="tableheader rounded-top-4 p-3">
                <span><i class="bi bi-calendar-plus"></i></span>
                @(Model != null && Model.MeetingMemberId > 0
                                ? "Edit Meeting Member"
                                : "Add New Meeting Member")
            </header>

            <form asp-action="Save"
                  method="post"
                  enctype="multipart/form-data"
                  class="p-4">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="MeetingMemberId" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <!-- Row 1 -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="mb-2">Meeting Name</label>
                        <div class="input-group mb-3">
                            <span class="input-group-text">
                                <i class="bi bi-tag"></i>
                            </span>
                            <select asp-for="MeetingID"
                                    asp-items="ViewBag.MeetingNameList"
                                    class="form-select">
                                <option value="">-- Select Meeting Type --</option>
                            </select>
                        </div>
                        <span asp-validation-for="MeetingID"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="mb-2">Staff Name</label>
                        <div class="input-group mb-3">
                            <span class="input-group-text">
                                <i class="bi bi-building"></i>
                            </span>
                            <select asp-for="StaffID"
                                    asp-items="ViewBag.StaffList"
                                    class="form-select">
                                <option value="">-- Select Staff --</option>
                            </select>
                        </div>
                        <span asp-validation-for="StaffID"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="mb-2">Remarks</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-chat-text"></i>
                        </span>
                        <textarea asp-for="Remarks"
                                  rows="4"
                                  placeholder="Enter meeting description and agenda"
                                  class="form-control"></textarea>
                    </div>
                    <span asp-validation-for="Remarks"
                          class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="mb-5">
                    <button type="submit"
                            class="btn btn-primary float-end">
                        <i class="bi bi-check-circle me-2"></i>
                        Save
                    </button>

                    <a asp-controller="Meeting"
                       asp-action="MeetingList"
                       class="btn btn-white float-end me-2">
                        <span class="me-1">&#x2190;</span>
                        Back to Meetings
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    a {
        text-decoration: none;
    }

    .bg-theme {
        background: linear-gradient(90deg, #4e54c8, #b700ff);
    }

    .tableheader {
        background: linear-gradient(90deg, #4e54c8, #b700ff);
        color: white;
    }

    .cardtable {
        box-shadow: 10px 10px 50px #4e54c8;
        width: 100%;
    }

    .bi {
        border-radius: 5px;
        padding: 3px;
        cursor: pointer;
    }
</style>