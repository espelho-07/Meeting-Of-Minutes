@model demo.Models.MeetingTypeModel

@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <h3>
        @(Model != null && Model.MeetingTypeID > 0
                ? "Edit Meeting Type"
                : "Add New Meeting Type")
    </h3>
    <p>Create a new meeting type.</p>

    <div class="d-flex justify-content-center p-3">
        <div class="cardtable rounded-4">

            <header class="tableheader rounded-top-4 p-3">
                <span><i class="bi bi-tag"></i></span>
                @(Model != null && Model.MeetingTypeID > 0
                                ? "Edit Meeting Type"
                                : "Add New Meeting Type")
            </header>

            <form asp-action="Save" method="post" class="p-4">
                @Html.AntiForgeryToken()

                <!-- Hidden ID for Edit -->                <input type="hidden" asp-for="MeetingTypeID" />

                <!-- Validation Summary -->                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Meeting Type -->                <label class="mb-2">Meeting Type</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-tag"></i>
                    </span>
                    <input asp-for="MeetingTypeName"
                           class="form-control"
                           placeholder="Enter meeting type name" />
                </div>
                <span asp-validation-for="MeetingTypeName" class="text-danger"></span>
                <p class="text-secondary">
                    e.g., Review Meeting, Planning Session, Training
                </p>

                <!-- Remarks -->                <label class="mb-2">Remarks</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-chat-text"></i>
                    </span>
                    <textarea asp-for="Remarks"
                              rows="4"
                              placeholder="Enter any additional remarks or description"
                              class="form-control border border-gray rounded-end-2"></textarea>
                </div>
                <span asp-validation-for="Remarks" class="text-danger"></span>
                <p class="text-secondary">
                    Optional: Add any additional context about this meeting type
                </p>

                <!-- Buttons -->                <div class="mb-5">
                    <button type="submit" class="btn btn-primary float-end">
                        <i class="bi bi-check-circle me-2"></i>
                        Save
                    </button>

                    <a asp-controller="MeetingType"
                       asp-action="MeetingTypeList"
                       class="btn btn-white float-end me-2">
                        <span class="me-1">&#x2190;</span> Back to List
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    a {
        text-decoration: none;
    }

    .bg-theme {
        background: linear-gradient(90deg, #4e54c8, #b700ff);
    }

    .tableheader {
        background: linear-gradient(90deg, #4e54c8, #b700ff);
        color: white;
    }

    .cardtable {
        box-shadow: 10px 10px 50px #4e54c8;
        width: 100%;
    }

    .bi {
        border-radius: 5px;
        padding: 3px;
        cursor: pointer;
    }
</style>
