@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>MOM System Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #4e54c8, #b700ff);
        }

        .login-card {
            background: #ffffff;
            border-radius: 14px;
            width: 100%;
            max-width: 600px;
        }

        .login-card {
            animation: fadeInUp 2s ease;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .signin {
            background: linear-gradient(90deg, #4e54c8, #b700ff, #4e54c8);
            background-size: 200% 100%;
            background-position: right;
            transition: background-position 1s;
        }

            .signin:hover {
                background-position: left;
            }


        .text-muted-small {
            color: black;
            font-size: 14px;
        }

        .link-color {
            color: #4e54c8;
            text-decoration: none;
        }

        .logo {
            /* background: transparent; */
            background: linear-gradient(135deg, #4e54c8, #b700ff);
            color: white;
            border-radius: 50%;
            width: 10%;
            /* text-align: center; */
            /* height: 5%; */
            font-size: xx-large;
        }

        a,
        h5 {
            color: #4e54c8;
            text-decoration: none;
            cursor: pointer;
        }

        span:hover {
            cursor: pointer;
        }

        button a {
            color: white;
            text-decoration: none;
        }

        .heading {
            letter-spacing: 3px;
        }

        a:hover {
            text-decoration: none;
        }

        .upper-section {
            background-color: rgb(230, 235, 255);
            border-top-left-radius: 14px;
            border-top-right-radius: 14px;
        }

        .bi-bg {
            background-color: rgb(230, 235, 255);
        }
    </style>
</head>

<body class="d-flex align-items-center justify-content-center">
    <div class="text-center">


        <div class="card mx-auto login-card shadow border border-0">

            <div class="upper-section p-3">

                <div class="text-center my-3">
                    <div class="brand-icon d-flex align-items-center justify-content-center mx-auto mb-2">
                        <i class="logo bi bi-person-plus"></i>
                        <h5 class="fw-bold ms-2 mt-2">Join MOM System</h5>
                    </div>
                </div>

                <h4 class="text-center fw-bold mb-3">Create Account</h4>
                <p class="text-center text-muted-small mb-4">
                    Join the meeting management system to organize and track meetings efficiently.
                </p>

            </div>

            <form class="p-4">
                <div class="input-group mb-3">
                    <span class="input-group-text bi-bg">
                        <i class="bi bi-person-fill"></i>
                    </span>
                    <input type="text" class="form-control shadow-none border border-start-0" placeholder="Username">
                </div>

                <div class="input-group">
                    <span class="input-group-text h-75 bi-bg">
                        <i class="bi bi-person-lines-fill"></i>
                    </span>
                    <select class="form-select mb-3 shadow-none border border-start-0" id="floatingSelect"
                            aria-label="Floating label select example">
                        <option selected>Select role</option>
                        <option value="1">Admin</option>
                        <option value="2">Staff</option>
                    </select>
                </div>

                <div class="input-group mb-3">
                    <span class="input-group-text bi-bg">
                        <i class="bi bi-key-fill"></i>
                    </span>
                    <input type="password" class="form-control shadow-none border border-start-0 border-end-0"
                           placeholder="Password">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-eye"></i>
                    </span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text bi-bg">
                        <i class="bi bi-shield-fill-check"></i>
                    </span>
                    <input type="password" class="form-control shadow-none border border-start-0 border-end-0"
                           placeholder="Confirm Password">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-eye"></i>
                    </span>
                </div>

                <div class="input-group mb-3">
                    <span class="input-group-text h-75 bi-bg">
                        <i class="bi bi-person-badge"></i>
                    </span>
                    <select class="form-select shadow-none mb-3 border border-start-0">
                        <option>Staff Member (Optional)</option>
                        <option>Admin</option>
                        <option>Staff</option>
                    </select>
                </div>

                <a asp-controller="Home" asp-action="Index" class="signin btn btn-gradient w-100 py-2 text-white" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-person-plus me-1"></i>Create Account
                </a>
                <hr class="my-4">

                <p class="text-center text-muted-small mb-0">
                    Already have an account?
                    <a asp-controller="Login" asp-action="Login" class="fw-semibold">Sign in here</a>
                </p>
            </form>


        </div>
    </div>
    </div>
    </div>
</body>

</html>