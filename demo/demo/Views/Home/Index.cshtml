@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: #f5f7fb;
    }

    .dashboard-title {
        font-weight: 600;
        color: #012970;
    }

    /* ===== STAT CARDS ===== */
    .stat-card {
        border: none;
        border-radius: 16px;
        padding: 18px;
        background: #fff;
        transition: all .3s ease;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 35px rgba(0,0,0,0.12);
        }

    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
    }

    .icon-primary {
        background: linear-gradient(135deg, #4154f1, #7387ff);
    }

    .icon-success {
        background: linear-gradient(135deg, #2eca6a, #5fe3a1);
    }

    .icon-info {
        background: linear-gradient(135deg, #0dcaf0, #66e3ff);
    }

    .icon-warning {
        background: linear-gradient(135deg, #ffb703, #ffd166);
    }

    .stat-label {
        font-size: 12px;
        color: #6c757d;
        letter-spacing: .5px;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: #012970;
    }

    /* ===== BADGES ===== */
    .soft-badge {
        font-size: 11px;
        padding: 5px 10px;
        border-radius: 20px;
    }

    .badge-success-soft {
        background: rgba(46,202,106,.15);
        color: #2eca6a;
    }

    .badge-danger-soft {
        background: rgba(220,53,69,.15);
        color: #dc3545;
    }

    /* ===== CHART CARDS ===== */
    .chart-card {
        border: none;
        border-radius: 16px;
        padding: 20px;
        background: #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .chart-title {
        font-size: 15px;
        font-weight: 600;
        color: #012970;
        margin-bottom: 10px;
    }

    /* SMALLER CHART SIZE */
    .chart-wrapper {
        height: 240px;
    }
</style>

<div class="container-fluid mt-4">

    <h3 class="dashboard-title mb-1">Dashboard</h3>
    <p class="text-muted mb-4">Meeting management overview & analytics</p>

    <!-- ===== STATISTICS ===== -->
    <div class="row g-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">TOTAL MEETINGS</div>
                        <div class="stat-value">14</div>
                        <span class="soft-badge badge-success-soft">
                            <i class="fa fa-arrow-up"></i> 12% this month
                        </span>
                    </div>
                    <div class="stat-icon icon-primary">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">UPCOMING</div>
                        <div class="stat-value">1</div>
                        <span class="soft-badge badge-success-soft">This week</span>
                    </div>
                    <div class="stat-icon icon-success">
                        <i class="fa fa-clock"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">COMPLETED</div>
                        <div class="stat-value">8</div>
                        <span class="soft-badge badge-success-soft">85% completion</span>
                    </div>
                    <div class="stat-icon icon-info">
                        <i class="fa fa-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">CANCELLED</div>
                        <div class="stat-value">5</div>
                        <span class="soft-badge badge-danger-soft">-3% rate</span>
                    </div>
                    <div class="stat-icon icon-warning">
                        <i class="fa fa-times-circle"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== CHARTS ===== -->
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">Meetings by Type</div>
                <div class="chart-wrapper">
                    <canvas id="meetingTypeChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">Meetings by Department</div>
                <div class="chart-wrapper">
                    <canvas id="meetingDeptChart"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    new Chart(document.getElementById('meetingTypeChart'), {
        type: 'doughnut',
        data: {
            labels: ['Planning', 'Review', 'Training', 'Discussion'],
            datasets: [{
                data: [4, 3, 2, 5],
                backgroundColor: ['#4154f1', '#2eca6a', '#ffb703', '#dc3545']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });

    new Chart(document.getElementById('meetingDeptChart'), {
        type: 'bar',
        data: {
            labels: ['HR', 'IT', 'Finance', 'Sales'],
            datasets: [{
                label: 'Meetings',
                data: [3, 5, 4, 2],
                backgroundColor: '#4154f1',
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 }
                }
            }
        }
    });
</script>
