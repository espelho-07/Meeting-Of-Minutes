@{
    ViewData["Title"] = "Dashboard - Meeting Of Minutes";
    var recentMeetings = ViewBag.RecentMeetings as List<MeetingsModel>;
}

@await Html.PartialAsync("_AlertMessages")

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="alert alert-success border-0 mb-4" style="border-left:4px solid #16c47f;background:linear-gradient(90deg,#ddfae8,#d5f7e2);border-radius:16px;">
        <div class="d-flex align-items-center justify-content-between">
            <div class="fw-bold text-success"><i class="bi bi-check-circle-fill me-2"></i>Welcome back, @Context.Session.GetString("UserName")!</div>
            <button type="button" class="btn-close" onclick="this.closest('.alert').remove()"></button>
        </div>
    </div>

    <div class="mom-page-header">
        <div>
            <h1>Dashboard</h1>
            <p class="mom-page-subtitle">Meeting management overview and analytics</p>
        </div>
        <div class="mom-toolbar">
            <button class="btn btn-light" onclick="location.reload();"><i class="bi bi-arrow-clockwise me-1 text-primary"></i> Refresh</button>
            <button class="btn btn-success"><i class="bi bi-download me-1"></i> Export Report</button>
        </div>
    </div>

    <div class="row">
        <div class="col-xxl-3 col-md-6 mb-4">
            <div class="card border-0" style="border-left:4px solid #5f58f4;background: linear-gradient(135deg, #f1f3ff 0%, #eef2ff 100%);">
                <div class="card-body p-4">
                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 55px; height: 55px; background-color: #5a52e0; color: white;"><i class="bi bi-calendar-event fs-4"></i></div>
                    <h2 class="fw-bold mb-1" style="font-size: 2.2rem; color: #1e2125;">14</h2>
                    <p class="text-uppercase fw-bold mb-2 small text-muted">Total Meetings</p>
                    <span class="badge" style="background:#ddfae8;color:#10b981;">12% from last month</span>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6 mb-4">
            <div class="card border-0" style="border-left:4px solid #19bf84;background: linear-gradient(135deg, #e9fff7 0%, #f3fff8 100%);">
                <div class="card-body p-4">
                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 55px; height: 55px; background-color: #18b981; color: white;"><i class="bi bi-calendar-plus fs-4"></i></div>
                    <h2 class="fw-bold mb-1" style="font-size: 2.2rem;">1</h2>
                    <p class="text-uppercase fw-bold mb-2 small text-muted">Upcoming</p>
                    <span class="badge" style="background:#ddfae8;color:#10b981;">8% from last week</span>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6 mb-4">
            <div class="card border-0" style="border-left:4px solid #3d86ff;background: linear-gradient(135deg, #eff5ff 0%, #f5f8ff 100%);">
                <div class="card-body p-4">
                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 55px; height: 55px; background-color: #3182ce; color: white;"><i class="bi bi-calendar-check fs-4"></i></div>
                    <h2 class="fw-bold mb-1" style="font-size: 2.2rem;">8</h2>
                    <p class="text-uppercase fw-bold mb-2 small text-muted">Completed</p>
                    <span class="badge" style="background:#ddfae8;color:#10b981;">15% completion rate</span>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6 mb-4">
            <div class="card border-0" style="border-left:4px solid #f5a000;background: linear-gradient(135deg, #fff9e6 0%, #fff7ee 100%);">
                <div class="card-body p-4">
                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 55px; height: 55px; background-color: #f59e0b; color: white;"><i class="bi bi-calendar-x fs-4"></i></div>
                    <h2 class="fw-bold mb-1" style="font-size: 2.2rem;">5</h2>
                    <p class="text-uppercase fw-bold mb-2 small text-muted">Cancelled</p>
                    <span class="badge" style="background:#ffe2e5;color:#ef4444;">3% cancellation rate</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center"><h6>Meetings by Type</h6><div><i class="bi bi-arrow-clockwise text-primary me-3"></i><i class="bi bi-download text-secondary"></i></div></div>
                <div class="card-body d-flex align-items-center justify-content-center" style="min-height:320px;">
                    <div class="text-center text-muted">Chart area</div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center"><h6>Meetings by Department</h6><div><i class="bi bi-arrow-clockwise text-primary me-3"></i><i class="bi bi-download text-secondary"></i></div></div>
                <div class="card-body d-flex align-items-center justify-content-center" style="min-height:320px;">
                    <div class="text-center text-muted">Chart area</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                        <h5 class="card-title fw-bold mb-0">Recent Meetings Logs</h5>
                        <div class="mom-search-input" style="max-width:320px;">
                            <span><i class="bi bi-search"></i></span>
                            <input type="text" id="meetingSearchInput" onkeyup="searchTable()" class="form-control" placeholder="Search meeting title...">
                        </div>
                    </div>

                    <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                        <table class="table table-hover align-middle" id="meetingTable">
                            <thead>
                                <tr>
                                    <th>Meeting Title</th>
                                    <th>Department</th>
                                    <th>Date</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentMeetings != null && recentMeetings.Count > 0)
                                {
                                    @foreach (var meeting in recentMeetings)
                                    {
                                        <tr>
                                            <td class="fw-bold">@meeting.MeetingDescription</td>
                                            <td>@meeting.DepartmentName</td>
                                            <td>@meeting.MeetingDate?.ToString("dd MMM yyyy")</td>
                                            <td class="text-center">
                                                @if (meeting.IsCancelled)
                                                {
                                                    <span class="badge bg-danger">Cancelled</span>
                                                }
                                                else if (meeting.MeetingDate > DateTime.Now)
                                                {
                                                    <span class="badge bg-warning text-dark">Upcoming</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Completed</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function searchTable() {
      var input = document.getElementById("meetingSearchInput");
      var filter = input.value.toUpperCase();
      var table = document.getElementById("meetingTable");
      var tr = table.getElementsByTagName("tr");

      for (var i = 0; i < tr.length; i++) {
        var td = tr[i].getElementsByTagName("td")[0];
        if (td) {
          var txtValue = td.textContent || td.innerText;
          tr[i].style.display = txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
        }
      }
    }
</script>
