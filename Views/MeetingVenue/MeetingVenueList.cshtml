@{
    ViewData["Title"] = "Meeting Venues - MOM";
}
@model List<MeetingVenueModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <h1>Meeting Venues</h1>
    <p class="text-muted">Manage meeting rooms and virtual meeting locations</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <a asp-action="MeetingVenueAddEdit" class="btn btn-primary rounded-pill px-4" style="background:#5a52e0; border:none;">
        <i class="bi bi-plus-circle me-1"></i> Add Venue
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px;overflow:hidden;">
    <div class="card-header border-0" style="background:linear-gradient(45deg,#5a52e0,#8965e0);padding:12px 20px;">
        <h6 class="mb-0 fw-bold text-white">Meeting Venue List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="small text-muted text-uppercase">
                    <th class="ps-4">#</th>
                    <th>Venue Name</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td class="ps-4">@SerialNumber</td>
                        <td>@v.MeetingVenueName</td>
                        <td class="text-center">
                            <a asp-action="MeetingVenueAddEdit" asp-route-id="@v.MeetingVenueID" class="btn btn-sm btn-light border rounded-pill"><i class="bi bi-pencil text-warning"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingVenueID" value="@v.MeetingVenueID" />
                                <button type="submit" class="btn btn-sm btn-light border rounded-pill"><i class="bi bi-trash text-danger"></i></button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>



