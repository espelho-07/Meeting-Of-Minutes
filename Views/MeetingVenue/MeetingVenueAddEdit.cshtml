@model Meeting_Of_Minutes.Models.MeetingVenueModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Venue Configuration - Meeting Of Minutes";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i> Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="MeetingVenue" asp-action="MeetingVenueList">Meeting Venue</a></li>
            <li class="breadcrumb-item active">Add Edit</li>
        </ol>
    </nav>
</div>

<div class="card border-0 shadow-sm col-lg-8 mx-auto mt-4" style="border-radius: 15px;">
    <div class="card-header border-0 py-3 text-white" style="background: linear-gradient(45deg, #5a52e0, #8965e0);">
        <h6 class="mb-0 fw-bold"><i class="bi bi-geo-alt-fill me-2"></i> Venue Details</h6>
    </div>

    <div class="card-body p-5">
        <form asp-controller="MeetingVenue" asp-action="Save" class="row g-4 js-update-confirm-form" data-id-field="MeetingVenueID" data-update-message="Sure to update this meeting venue?" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MeetingVenueID" />
            <div class="col-md-12">
                <label class="form-label small fw-bold text-muted">Meeting Venue Name</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-door-open"></i></span>
                    <input asp-for="MeetingVenueName" type="text" class="form-control border-start-0 ps-0 shadow-none" maxlength="100">
                </div>
                <span asp-validation-for="MeetingVenueName" class=" text-danger"></span>
            </div>

            <div class="text-end mt-5 border-top pt-4">
                <a asp-action="MeetingVenueList" class="btn btn-light rounded-pill px-4 me-2">Cancel</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm" style="background:#5a52e0; border:none;"><i class="bi bi-save me-2"></i> Save Venue</button>
            </div>
        </form>
    </div>
</div>
