@{
    ViewData["Title"] = "Staff Members - Meeting Of Minutes";
}
@model List<StaffModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle">
    <h1>Staff Members</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item active">Staff Members</li>
        </ol>
    </nav>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted small mb-0">Manage staff access and view organizational participation.</p>
    <a asp-action="StaffAddEdit" class="btn btn-primary rounded-pill px-4 shadow-sm" style="background-color:#5a52e0;border:none;">
        <i class="bi bi-person-plus-fill me-2"></i>
        Add Staff Member
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px;overflow:hidden;">
    <div class="card-header border-0" style="background:linear-gradient(45deg,#5a52e0,#8965e0);padding:12px 20px;">
        <h6 class="mb-0 fw-bold text-white">Staff List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0" id="staffTable">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase">
                    <th class="ps-4">ID</th>
                    <th>Staff Member</th>
                    <th>DepartmentID</th>
                    <th>Mobile & Email</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Model)
                {
                    <tr>
                        <td class="ps-4">@SerialNumber</td>
                        <td><div class="fw-bold">@staff.StaffName</div></td>
                        <td>@staff.DepartmentID</td>
                        <td>@staff.MobileNo<br /><small>@staff.EmailAddress</small></td>
                        <td class="text-center">
                            <a asp-action="StaffAddEdit" asp-route-id="@staff.StaffID" class="btn btn-sm btn-light border rounded-pill">
                                <i class="bi bi-pencil-square text-warning"></i>
                            </a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="StaffID" value="@staff.StaffID" />
                                <button type="submit" class="btn btn-sm btn-light border rounded-pill">
                                    <i class="bi bi-trash3 text-danger"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>



