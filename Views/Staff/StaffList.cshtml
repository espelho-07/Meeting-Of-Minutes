@{
    ViewData["Title"] = "Staff Members - Meeting Of Minutes";
}
@model List<StaffModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item active">Staff Members</li>
        </ol>
    </nav>
</div>

<div class="mom-page-header">
    <div>
        <h1>Staff Members</h1>
        <p class="mom-page-subtitle">Manage staff access and organizational participation</p>
    </div>
    <div class="mom-toolbar">
        <a asp-action="StaffAddEdit" class="btn btn-primary px-4"><i class="bi bi-person-plus-fill me-2"></i>Add Staff Member</a>
        <a asp-action="ExportToExcel" class="btn btn-success px-4"><i class="bi bi-file-earmark-excel me-2"></i>Export</a>
    </div>
</div>

<div class="mom-search-card">
    <form class="mom-search-form" asp-action="StaffList" asp-controller="Staff" method="post">
        @Html.AntiForgeryToken()
        <div class="mom-search-input">
            <span><i class="bi bi-search"></i></span>
            <input class="form-control" name="searchtext" value="@ViewBag.searchtext" type="text" placeholder="Search staff members..." />
        </div>
        <button class="btn btn-primary px-4" type="submit">Search</button>
        <a href="@Url.Action("StaffList", "Staff")" class="btn btn-light px-4">Clear</a>
    </form>
    <div class="mom-stat-chip">Total Records: @Model.Count</div>
</div>

<div class="card mom-list-card">
    <div class="card-header">
        <h6><i class="bi bi-people"></i> Staff List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0" id="staffTable">
            <thead>
                <tr>
                    <th style="width:44px;"></th>
                    <th class="ps-4">#</th>
                    <th>Staff Member</th>
                    <th>Department Name</th>
                    <th>Mobile & Email</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input" /></td>
                        <td class="ps-4">@SerialNumber</td>
                        <td><div class="fw-bold">@staff.StaffName</div></td>
                        <td>@staff.DepartmentName</td>
                        <td>@staff.MobileNo<br /><small>@staff.EmailAddress</small></td>
                        <td class="text-center">
                            <a asp-action="StaffAddEdit" asp-route-id="@staff.StaffID" class="mom-icon-btn">
                                <i class="bi bi-pencil-square text-warning"></i>
                            </a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="StaffID" value="@staff.StaffID" />
                                <button type="submit" class="btn btn-sm btn-link mom-icon-btn p-0">
                                    <i class="bi bi-trash3 text-danger"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>
