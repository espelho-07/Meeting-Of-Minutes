@model Meeting_Of_Minutes.Models.StaffModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Staff Member Configuration - MOM";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="Staff" asp-action="StaffList">Staff Members</a></li>
            <li class="breadcrumb-item active">Add Edit</li>
        </ol>
    </nav>
</div>

<div class="mom-form-wrap">
    <div class="mb-4">
        <h1>@(Model.StaffID == 0 ? "Add New Staff Member" : "Edit Staff Member")</h1>
        <p class="mom-page-subtitle">Register a new staff member</p>
    </div>

    <div class="card mom-form-card col-lg-9 mx-auto">
        <div class="card-header">
            <h6><i class="bi bi-person-plus-fill me-2"></i> Add New Staff Member</h6>
        </div>
        <div class="card-body">
            <form asp-action="Save" class="row g-4 js-update-confirm-form" data-id-field="StaffID" data-update-message="Sure to update this staff?" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="StaffID" />
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Staff Name</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input asp-for="StaffName" type="text" class="form-control" placeholder="Enter staff name" maxlength="50"></div>
                    <span asp-validation-for="StaffName" class=" text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold">Department</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-building"></i></span><select asp-for="DepartmentID" asp-items="ViewBag.DepartmentDropDown" class="form-select"><option value="">-- Select Department --</option></select></div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Email Address</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-envelope"></i></span><input asp-for="EmailAddress" type="email" class="form-control" placeholder="Enter email address" maxlength="50"></div>
                    <span asp-validation-for="EmailAddress" class=" text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold">Mobile Number</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-phone"></i></span><input asp-for="MobileNo" type="text" class="form-control" placeholder="Enter mobile number" maxlength="20"></div>
                    <small class="text-muted">Example: +91 98765 43210</small>
                    <span asp-validation-for="MobileNo" class=" text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-bold">Remarks</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-chat-left-text"></i></span><textarea asp-for="Remarks" class="form-control" rows="3" maxlength="250" placeholder="Enter any additional remarks (optional)"></textarea></div>
                </div>
                <div class="col-12 mom-form-actions">
                    <a asp-action="StaffList" class="btn btn-light px-4">Back to List</a>
                    <button type="submit" class="btn btn-primary px-5">@(Model.StaffID == 0 ? "Create Staff Member" : "Update Staff Member")</button>
                </div>
            </form>
        </div>
    </div>
</div>
