@model Meeting_Of_Minutes.Models.StaffModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Staff Member Configuration - MOM";
}

<div class="pagetitle">
    <h1>Staff Member Configuration</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Staff" asp-action="StaffList">Staff Members</a></li>
            <li class="breadcrumb-item active">Add/Edit</li>
        </ol>
    </nav>
</div>

<div class="card border-0 shadow-sm col-lg-9 mx-auto" style="border-radius: 15px;">
    <div class="card-header border-0 py-3 text-white" style="background: linear-gradient(45deg, #5a52e0, #8965e0);">
        <h6 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill me-2"></i> Staff Details</h6>
    </div>
    <div class="card-body p-4 pt-5">
        <form asp-action="Save" class="row g-4 js-update-confirm-form" data-id-field="StaffID" data-update-message="Sure to update this staff?" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StaffID" />
            <div class="col-md-6">
                <label class="form-label small fw-bold">Staff Name</label>
                <input asp-for="StaffName" type="text" class="form-control rounded-3 shadow-none" maxlength="50">
                <span asp-validation-for="StaffName" class=" text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label small fw-bold">Department</label>
                <select asp-for="DepartmentID" asp-items="ViewBag.DepartmentDropDown" class="form-select rounded-3 shadow-none">
                    <option value="">-- Select Department --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-bold">Mobile Number</label>
                <input asp-for="MobileNo" type="text" class="form-control rounded-3 shadow-none" maxlength="20">
                <span asp-validation-for="MobileNo" class=" text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label small fw-bold">Email Address</label>
                <input asp-for="EmailAddress" type="email" class="form-control rounded-3 shadow-none" maxlength="50">
                <span asp-validation-for="EmailAddress" class=" text-danger"></span>
            </div>

            <div class="col-12">
                <label class="form-label small fw-bold">Remarks</label>
                <textarea asp-for="Remarks" class="form-control rounded-3 shadow-none" rows="3" maxlength="250"></textarea>
            </div>
            <div class="col-12 text-end border-top pt-4">
                <a asp-action="StaffList" class="btn btn-light rounded-pill px-4">Cancel</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm" style="background:#5a52e0; border:none;">Save Member</button>
            </div>
        </form>
    </div>
</div>




