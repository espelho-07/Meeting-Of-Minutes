@model List<MeetingMemberModel>

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Attendance - Meeting Of Minutes";
}

<div class="pagetitle">
    <h1>Meeting Attendance</h1>
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Meetings" asp-action="MeetingsList">Meetings</a></li>
            <li class="breadcrumb-item active">Meeting Member</li>
        </ol>
    </nav>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted small mb-0">Track participation and attendance records for scheduled meetings.</p>
    <a asp-action="MeetingMemberAddEdit" class="btn btn-primary rounded-pill px-4 shadow-sm" style="background-color:#5a52e0;border:none;">
        <i class="bi bi-person-plus-fill me-2"></i>
        Add Meeting Member
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px;overflow:hidden;">
    <div class="card-header border-0" style="background:linear-gradient(45deg,#5a52e0,#8965e0);padding:12px 20px;">
        <h6 class="mb-0 fw-bold text-white">Meeting Member List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="small text-muted text-uppercase">
                    <th class="ps-4">MemberID</th>
                    <th>MeetingID</th>
                    <th>StaffID</th>
                    <th class="text-center">IsPresent</th>
                    <th>Remarks</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    <tr>
                        <td class="ps-4">@member.MeetingMemberID</td>
                        <td>@member.MeetingID</td>
                        <td>@member.StaffID</td>
                        <td class="text-center">@(member.IsPresent ? "Yes" : "No")</td>
                        <td>@member.Remarks</td>
                        <td class="text-center">
                            <a asp-action="MeetingMemberAddEdit" asp-route-id="@member.MeetingMemberID" class="btn btn-sm btn-light border rounded-pill"><i class="bi bi-pencil text-warning"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingMemberID" value="@member.MeetingMemberID" />
                                <button type="submit" class="btn btn-sm btn-light border rounded-pill"><i class="bi bi-trash text-danger"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



