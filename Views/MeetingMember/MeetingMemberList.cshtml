@model List<MeetingMemberModel>

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Attendance - Meeting Of Minutes";
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="Meetings" asp-action="MeetingsList">Meetings</a></li>
            <li class="breadcrumb-item active">Attendance</li>
        </ol>
    </nav>
</div>

<div class="mom-page-header">
    <div>
        <h1>Meeting Attendance</h1>
        <p class="mom-page-subtitle">Track participation and attendance records for scheduled meetings</p>
    </div>
    <div class="mom-toolbar">
        <a asp-action="MeetingMemberAddEdit" class="btn btn-primary px-4"><i class="bi bi-person-plus-fill me-2"></i>Add Meeting Member</a>
        <a asp-action="ExportToExcel" class="btn btn-success px-4"><i class="bi bi-file-earmark-excel me-2"></i>Export</a>
    </div>
</div>

<div class="card mom-list-card">
    <div class="card-header">
        <h6><i class="bi bi-person-check"></i> Meeting Member List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:44px;"></th>
                    <th class="ps-4">#</th>
                    <th>Meeting</th>
                    <th>Staff</th>
                    <th class="text-center">IsPresent</th>
                    <th>Remarks</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input" /></td>
                        <td class="ps-4">@SerialNumber</td>
                        <td>@member.MeetingDescription</td>
                        <td>@member.StaffName</td>
                        <td class="text-center">@(member.IsPresent ? "Yes" : "No")</td>
                        <td>@member.Remarks</td>
                        <td class="text-center">
                            <a asp-action="MeetingMemberAddEdit" asp-route-id="@member.MeetingMemberID" class="mom-icon-btn"><i class="bi bi-pencil text-warning"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingMemberID" value="@member.MeetingMemberID" />
                                <button type="submit" class="btn btn-sm btn-link mom-icon-btn p-0"><i class="bi bi-trash text-danger"></i></button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>
