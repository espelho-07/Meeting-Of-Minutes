@model Meeting_Of_Minutes.Models.MeetingMemberModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Attendance Edit - Meeting Of Minutes";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="MeetingMember" asp-action="MeetingMemberList">Attendance</a></li>
            <li class="breadcrumb-item active">Add Edit</li>
        </ol>
    </nav>
</div>

<div class="mom-form-wrap">
    <div class="mb-4">
        <h1>@(Model.MeetingMemberID == 0 ? "Add Attendance Record" : "Update Attendance")</h1>
        <p class="mom-page-subtitle">Manage member attendance for meetings</p>
    </div>

    <div class="card mom-form-card col-lg-8 mx-auto">
        <div class="card-header">
            <h6><i class="bi bi-person-check me-2"></i> Update Attendance</h6>
        </div>
        <div class="card-body">
            <form class="row g-4 js-update-confirm-form" data-id-field="MeetingMemberID" data-update-message="Sure to update this meeting member?" method="post" asp-action="Save">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MeetingMemberID" />

                <div class="col-md-6">
                    <label class="form-label small fw-bold">Meeting</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-calendar-event"></i></span><select asp-for="MeetingID" asp-items="ViewBag.MeetingDropDown" class="form-select"><option value="">-- Select Meeting --</option></select></div>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold">Select Staff Member</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-people"></i></span><select asp-for="StaffID" asp-items="ViewBag.StaffDropDown" class="form-select"><option value="">-- Select Staff --</option></select></div>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold">Is Present?</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-check2-square"></i></span><select asp-for="IsPresent" class="form-select"><option value="true">Yes (Present)</option><option value="false">No (Absent)</option></select></div>
                </div>
                <div class="col-md-12">
                    <label class="form-label small fw-bold">Remarks</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-chat-left-text"></i></span><textarea asp-for="Remarks" class="form-control" rows="3" maxlength="250"></textarea></div>
                </div>
                <div class="col-12 mom-form-actions">
                    <a asp-action="MeetingMemberList" class="btn btn-light px-4">Back to List</a>
                    <button type="submit" class="btn btn-primary px-5">Update Record</button>
                </div>
            </form>
        </div>
    </div>
</div>
