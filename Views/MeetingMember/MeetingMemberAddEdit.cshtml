@model Meeting_Of_Minutes.Models.MeetingMemberModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Attendance Edit - Meeting Of Minutes";
}

<div class="card border-0 shadow-sm col-lg-8 mx-auto mt-4" style="border-radius: 15px;">
    <div class="card-header border-0 py-3 text-white" style="background: #5a52e0;">
        <h6 class="mb-0 fw-bold"><i class="bi bi-person-check me-2"></i> Update Attendance</h6>
    </div>
    <div class="card-body p-5">
        <form class="row g-4 js-update-confirm-form" data-id-field="MeetingMemberID" data-update-message="Sure to update this meeting member?" method="post" asp-action="Save">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MeetingMemberID" />

            <div class="col-md-6">
                <label class="form-label small fw-bold">Meeting</label>
                <select asp-for="MeetingID" asp-items="ViewBag.MeetingDropDown" class="form-select rounded-3 shadow-none">
                    <option value="">-- Select Meeting --</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label small fw-bold">Select Staff Member</label>
                <select asp-for="StaffID" asp-items="ViewBag.StaffDropDown" class="form-select rounded-3 shadow-none">
                    <option value="">-- Select Staff --</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label small fw-bold">Is Present? (Bit)</label>
                <select asp-for="IsPresent" class="form-select rounded-3 shadow-none">
                    <option value="true">Yes (Present)</option>
                    <option value="false">No (Absent)</option>
                </select>
            </div>
            <div class="col-md-12">
                <label class="form-label small fw-bold">Remarks</label>
                <textarea asp-for="Remarks" class="form-control rounded-3 shadow-none" rows="3" maxlength="250"></textarea>
            </div>
            <div class="text-end mt-4 pt-3 border-top">
                <a asp-action="MeetingMemberList" class="btn btn-light rounded-pill px-4">Cancel</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm" style="background:#5a52e0; border:none;">Update Record</button>
            </div>
        </form>
    </div>
</div>




