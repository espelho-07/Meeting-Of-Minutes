@model Meeting_Of_Minutes.Models.UserModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | Meetings Of Minutes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #4538d6 0%, #4935d8 50%, #4338ca 100%);
            font-family: "Nunito", sans-serif;
        }

        .auth-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            position: relative;
        }

        .auth-brand {
            position: absolute;
            top: 48px;
            left: 50%;
            transform: translateX(-50%);
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 1.1rem;
        }

        .auth-card {
            width: 100%;
            max-width: 474px;
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 30px 60px rgba(21, 25, 71, 0.22);
            overflow: hidden;
        }

        .auth-card-top {
            background: linear-gradient(180deg, #f6f7ff 0%, #ffffff 100%);
            padding: 36px 36px 18px;
            text-align: center;
        }

        .auth-card-body {
            padding: 24px 36px 30px;
        }

        .auth-icon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #6a6ff2, #7f55cf);
            color: #fff;
            font-size: 1.6rem;
            margin-bottom: 12px;
        }

        .auth-title {
            font-size: 2.1rem;
            font-weight: 800;
            color: #111827;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            color: #64748b;
            margin-bottom: 0;
        }

        .auth-label {
            font-size: 0.86rem;
            font-weight: 700;
            color: #7c6cff;
            margin-bottom: 6px;
        }

        .auth-input-group {
            display: flex;
            align-items: center;
            border: 1px solid #d9e2f2;
            border-radius: 12px;
            background: #eef4ff;
            overflow: hidden;
        }

        .auth-input-group span {
            width: 48px;
            text-align: center;
            color: #95a2bb;
        }

        .auth-input-group input {
            border: 0;
            background: transparent;
            box-shadow: none !important;
            min-height: 48px;
        }

        .auth-link,
        .auth-link:hover {
            color: #6165f0;
            text-decoration: none;
            font-weight: 700;
        }

        .signin {
            background: linear-gradient(90deg, #6674f4, #7a4db8);
            border: 0;
            border-radius: 10px;
            min-height: 46px;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <div class="auth-brand">
            <i class="bi bi-calendar-check fs-4"></i>
            <span>MOM System</span>
        </div>

        <div class="auth-card">
            <div class="auth-card-top">
                <div class="auth-icon"><i class="bi bi-calendar-check"></i></div>
                <div class="fw-bold fs-3" style="color:#5f62ee;">MOM System</div>
                <div class="auth-title">Welcome Back</div>
                <p class="auth-subtitle">Sign in to access your meeting management dashboard</p>
            </div>

            <div class="auth-card-body">
                <form method="post" asp-controller="Auth" asp-action="Login">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger text-start mb-2"></div>

                    <label class="auth-label" asp-for="UserName">Username</label>
                    <div class="auth-input-group mb-3">
                        <span><i class="bi bi-person"></i></span>
                        <input asp-for="UserName" type="text" class="form-control" placeholder="Enter username">
                    </div>
                    <span asp-validation-for="UserName" class="text-danger d-block text-start mb-2"></span>

                    <label class="auth-label" asp-for="Password">Password</label>
                    <div class="auth-input-group mb-3">
                        <span><i class="bi bi-key"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" id="loginPassword">
                        <span style="width:44px;cursor:pointer;" onclick="toggleLoginPassword()"><i class="bi bi-eye"></i></span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger d-block text-start mb-3"></span>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-muted" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="auth-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="signin btn w-100 py-2 text-white">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                    </button>
                </form>

                <hr class="my-4">
                <p class="mb-0 text-center">Don't have an account? <a class="auth-link" asp-controller="Auth" asp-action="Register">Create an account</a></p>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleLoginPassword() {
            const input = document.getElementById('loginPassword');
            if (!input) return;
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
