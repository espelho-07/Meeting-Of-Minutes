@model Meeting_Of_Minutes.Models.DepartmentModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Department Details";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="Department" asp-action="DepartmentList">Departments</a></li>
            <li class="breadcrumb-item active">Department Details</li>
        </ol>
    </nav>
</div>

<div class="mom-detail-grid">
    <div>
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6><i class="bi bi-building me-2"></i> Department Information</h6>
                <div class="d-flex gap-3 small">
                    <a asp-action="DepartmentAddEdit" asp-route-id="@Model.DepartmentID" class="text-warning text-decoration-none"><i class="bi bi-pencil"></i> Edit</a>
                    <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="DepartmentID" value="@Model.DepartmentID" />
                        <button type="submit" class="btn btn-link text-danger p-0 text-decoration-none"><i class="bi bi-trash"></i> Delete</button>
                    </form>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row gy-4">
                    <div class="col-md-6">
                        <div class="text-muted small">Department ID</div>
                        <div class="fw-bold fs-5">@Model.DepartmentID</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small">Department Name</div>
                        <span class="badge bg-primary px-3 py-2">@Model.DepartmentName</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <div class="mom-stat-card mb-4">
            <div class="mom-stat-card-head"><i class="bi bi-bar-chart me-2"></i>Department Statistics</div>
            <div class="mom-stat-card-body">
                <div class="mom-detail-stats">
                    <div>
                        <div class="fs-2 fw-bold text-primary">@Model.StaffCount</div>
                        <div class="text-muted small">Total Staff Members</div>
                    </div>
                    <div>
                        <div class="fs-2 fw-bold text-warning">@Model.MeetingsCount</div>
                        <div class="text-muted small">Total Meetings</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
