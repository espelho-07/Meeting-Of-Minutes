@model Meeting_Of_Minutes.Models.DepartmentModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Department Details";
}

<div class="container-fluid mt-4">
    <div class="pagetitle">
        <h1>Departments Details</h1>
        <nav>
            <ol class="breadcrumb flex-nowrap">
                <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Department" asp-action="DepartmentList">Departments</a></li>
                <li class="breadcrumb-item active">Departments Details</li>
            </ol>
        </nav>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:14px;">
        <div class="card-header text-white d-flex justify-content-between align-items-center" style="background:linear-gradient(90deg,#6a6fdc,#7b5be6);border-radius:14px 14px 0 0;">
            <span><i class="bi bi-building me-2"></i> Department Information</span>
            <div class="d-flex gap-3 small">
                <a asp-action="DepartmentAddEdit" asp-route-id="@Model.DepartmentID" class="text-warning text-decoration-none"><i class="bi bi-pencil"></i> Edit</a>
                <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DepartmentID" value="@Model.DepartmentID" />
                    <button type="submit" class="btn btn-link text-danger p-0 text-decoration-none"><i class="bi bi-trash"></i> Delete</button>
                </form>
            </div>
        </div>

        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <small class="text-muted">Department ID</small>
                    <div class="fw-semibold">@Model.DepartmentID</div>
                </div>
                <div class="col-md-6">
                    <small class="text-muted">Department Name</small><br />
                    <span class="badge bg-primary px-3 py-2 rounded-pill">@Model.DepartmentName</span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <small class="text-muted">Staff Count</small>
                    <div>@Model.StaffCount</div>
                </div>
                <div class="col-md-6">
                    <small class="text-muted">Meetings Count</small>
                    <div>@Model.MeetingsCount</div>
                </div>
            </div>
        </div>
    </div>
</div>



