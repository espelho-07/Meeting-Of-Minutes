@model Meeting_Of_Minutes.Models.DepartmentModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Department Add - Meeting Of Minutes";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="Department" asp-action="DepartmentList">Departments</a></li>
            <li class="breadcrumb-item active">Add Edit</li>
        </ol>
    </nav>
</div>

<div class="mom-form-wrap">
    <div class="mb-4">
        <h1>@(Model.DepartmentID == 0 ? "Add Department" : "Edit Department")</h1>
        <p class="mom-page-subtitle">Configure department information</p>
    </div>

    <div class="card mom-form-card col-lg-8 mx-auto">
        <div class="card-header">
            <h6><i class="bi bi-building me-2"></i> Department Details</h6>
        </div>

        <div class="card-body">
            <form class="row g-4 js-update-confirm-form" data-id-field="DepartmentID" data-update-message="Sure to update this department?" asp-action="Save" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="DepartmentID" />
                <div class="col-md-12">
                    <label asp-for="DepartmentName" class="form-label small fw-bold text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-building"></i></span>
                        <input asp-for="DepartmentName" type="text" class="form-control" placeholder="Enter department name" maxlength="100">
                    </div>
                    <span asp-validation-for="DepartmentName" class="text-danger"></span>
                </div>

                <div class="col-12 mom-form-actions">
                    <a asp-action="DepartmentList" class="btn btn-light px-4">Back to List</a>
                    <button type="submit" class="btn btn-primary px-5"><i class="bi bi-check-circle me-2"></i>Save Department</button>
                </div>
            </form>
        </div>
    </div>
</div>
