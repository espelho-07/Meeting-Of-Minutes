@{
    ViewData["Title"] = "Departments - Meeting Of Minutes";
}

@model List<DepartmentModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <h1>Departments</h1>
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item active">Departments</li>
        </ol>
    </nav>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1">Departments</h5>
        <p class="text-muted mb-0">Manage organizational departments and their staff members</p>
    </div>

    <a asp-action="DepartmentAddEdit" class="btn btn-primary rounded-pill px-4" style="background:#6a5ae0;border:none;">
        <i class="bi bi-plus-circle me-1"></i> Add Department
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-header text-white d-flex justify-content-between align-items-center" style="background:linear-gradient(90deg,#6a5ae0,#7f6ae6);border-radius:16px 16px 0 0;">
        <div class="fw-semibold"><i class="bi bi-building me-2"></i> Departments List</div>
    </div>

    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead class="bg-light small text-uppercase text-muted">
                <tr>
                    <th style="width:60px;">#</th>
                    <th>Department Name</th>
                    <th>Staff Count</th>
                    <th>Meetings</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var dept in Model)
                {
                    <tr>
                        <td>@(SerialNumber++)</td>
                        <td class="fw-semibold">@dept.DepartmentName</td>
                        <td>@dept.StaffCount</td>
                        <td>@dept.MeetingsCount</td>
                        <td class="text-center">
                            <a asp-action="DepartmentView" asp-route-id="@dept.DepartmentID" class="text-primary me-2" title="View"><i class="bi bi-eye"></i></a>
                            <a asp-action="DepartmentAddEdit" asp-route-id="@dept.DepartmentID" class="text-warning me-2" title="Edit"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="DepartmentID" value="@dept.DepartmentID" />
                                <button type="submit" class="btn btn-link text-danger p-0" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>







