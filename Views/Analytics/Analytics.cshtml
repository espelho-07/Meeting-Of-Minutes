@{
    ViewData["Title"] = "Analytics - Meeting Of Minutes";
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item active">Analytics</li>
        </ol>
    </nav>
</div>

<div class="mom-page-header">
    <div>
        <h1>Analytics</h1>
        <p class="mom-page-subtitle">Visual insights based on meeting records</p>
    </div>
    <div class="mom-toolbar">
        <div class="btn-group">
            <button class="btn btn-light">Month</button>
            <button class="btn btn-primary">Quarter</button>
            <button class="btn btn-light">Year</button>
        </div>
    </div>
</div>

<section class="section dashboard">
    <div class="row">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header"><h6>Meeting Trends</h6></div>
                <div class="card-body">
                    <div id="meetingTrendsChart"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header"><h6>Completion Rate</h6></div>
                <div class="card-body">
                    <div id="statusChart" class="d-flex justify-content-center align-items-center" style="min-height: 300px;"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mt-4">
            <div class="card">
                <div class="card-header"><h6>Department Activity</h6></div>
                <div class="card-body">
                    <div id="deptBarChart"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mt-4">
            <div class="card">
                <div class="card-header"><h6>Meeting Categories</h6></div>
                <div class="card-body">
                    <div id="categoryRadarChart"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            new ApexCharts(document.querySelector("#meetingTrendsChart"), {
                series: [{ name: "Meetings", data: [12, 18, 15, 25, 20, 32, 28] }, { name: "Cancelled", data: [2, 1, 3, 0, 2, 1, 4] }],
                chart: { height: 350, type: 'area', toolbar: { show: false }, zoom: { enabled: false } },
                dataLabels: { enabled: false }, stroke: { curve: 'smooth' }, xaxis: { type: 'category', categories: ["Jul", "Aug", "Sep", "Oct", "Nov", "Dec", "Jan"] },
                colors: ['#4154f1', '#ff771d'], fill: { type: "gradient", gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.4, stops: [0, 90, 100] } }
            }).render();

            new ApexCharts(document.querySelector("#statusChart"), {
                series: [44, 55, 13], chart: { height: 350, type: 'donut', toolbar: { show: false } }, labels: ['Completed', 'Scheduled', 'Rescheduled'],
                colors: ['#2eca6a', '#4154f1', '#ffc107'], dataLabels: { enabled: false }, legend: { position: 'bottom' }
            }).render();

            new ApexCharts(document.querySelector("#deptBarChart"), {
                series: [{ data: [24, 18, 12, 9, 5] }], chart: { type: 'bar', height: 350, toolbar: { show: false } },
                plotOptions: { bar: { borderRadius: 4, horizontal: true, barHeight: '40%' } }, dataLabels: { enabled: false },
                xaxis: { categories: ['IT Dept', 'Management', 'HR', 'Finance', 'Operations'] }, colors: ['#798eb3']
            }).render();

            new ApexCharts(document.querySelector("#categoryRadarChart"), {
                series: [{ name: 'Avg Duration (Mins)', data: [60, 45, 30, 90, 20, 40] }], chart: { height: 350, type: 'radar', toolbar: { show: false } },
                xaxis: { categories: ['Board Meeting', 'Scrum', 'Review', 'Training', 'Client Call', 'Audit'] }, colors: ['#e91e63'], fill: { opacity: 0.2 }
            }).render();
        });
    </script>
}
