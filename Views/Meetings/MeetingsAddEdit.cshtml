@model Meeting_Of_Minutes.Models.MeetingsModel

@await Html.PartialAsync("_AlertMessages")

@{
    ViewData["Title"] = "Schedule New Meeting";
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h4 class="fw-bold">Schedule New Meeting</h4>
        <p class="text-muted mb-0">Create and schedule a new organizational meeting</p>
    </div>

    <div class="card border-0 shadow-sm col-lg-8 mx-auto" style="border-radius:14px;">
        <div class="card-header text-white border-0" style="background:linear-gradient(90deg,#6a6fdc,#7b5be6);border-radius:14px 14px 0 0;">
            <i class="bi bi-calendar-plus me-2"></i> Schedule New Meeting
        </div>

        <div class="card-body p-4">
            <form asp-action="Save" method="post" class="row g-4 js-update-confirm-form" data-id-field="MeetingID" data-update-message="Sure to update this meeting?">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MeetingID" />

                <div class="col-12">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Meeting Type</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-tags"></i></span>
                        <select asp-for="MeetingTypeID" asp-items="ViewBag.MeetingTypeDropDown" class="form-select">
                            <option value="">-- Select Meeting Type --</option>
                        </select>
                    </div>
                    <span asp-validation-for="MeetingTypeID" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Department</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-building"></i></span>
                        <select asp-for="DepartmentID" asp-items="ViewBag.DepartmentDropDown" class="form-select">
                            <option value="">-- Select Department --</option>
                        </select>
                    </div>
                    <span asp-validation-for="DepartmentID" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Venue</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
                        <select asp-for="MeetingVenueID" asp-items="ViewBag.MeetingVenueDropDown" class="form-select">
                            <option value="">-- Select Venue --</option>
                        </select>
                    </div>
                    <span asp-validation-for="MeetingVenueID" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Meeting Date & Time</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                        <input asp-for="MeetingDate" type="datetime-local" class="form-control" />
                    </div>
                    <span asp-validation-for="MeetingDate" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold">Meeting Description</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white align-items-start"><i class="bi bi-text-paragraph mt-1"></i></span>
                        <textarea asp-for="MeetingDescription" class="form-control" rows="3" maxlength="250" placeholder="Enter meeting description and agenda"></textarea>
                    </div>
                    <span asp-validation-for="MeetingDescription" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold">Document Path (Optional)</label>
                    <input asp-for="DocumentPath" type="text" class="form-control" placeholder="/docs/meeting.pdf" />
                </div>

                <div class="col-12 d-flex justify-content-between mt-3">
                    <a asp-action="MeetingsList" class="btn btn-link text-decoration-none">? Back to Meetings</a>
                    <button type="submit" class="btn text-white px-4" style="background:#4f46e5;border-radius:10px;">
                        <i class="bi bi-check-circle me-1"></i> Save Meeting
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>




