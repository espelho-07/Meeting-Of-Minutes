@{
    ViewData["Title"] = "Meetings Management - MOM";
}

@model List<MeetingsModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <h1>Meetings</h1>
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item active">Meetings</li>
        </ol>
    </nav>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="fw-bold mb-1">Meetings Management</h5>
        <p class="text-muted mb-0">Schedule and manage organizational meetings</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="MeetingsAddEdit" class="btn btn-primary rounded-pill px-4 shadow-sm" style="background:#5a52e0;border:none;">
            <i class="bi bi-plus-circle me-2"></i> Schedule Meeting
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px;">
    <div class="card-header text-white" style="background:linear-gradient(45deg,#5a52e0,#8965e0)">
        <i class="bi bi-calendar-event me-2"></i> Scheduled Meetings
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light small text-uppercase text-muted">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Date & Time</th>
                    <th>Meeting Type</th>
                    <th>Description</th>
                    <th>Department</th>
                    <th>Venue</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var meeting in Model)
                {
                    <tr>
                        <td class="ps-4">@SerialNumber</td>
                        <td>@meeting.MeetingDate</td>
                        <td>@meeting.MeetingTypeName</td>
                        <td>@meeting.MeetingDescription</td>
                        <td>@meeting.DepartmentName</td>
                        <td>@meeting.MeetingVenueName</td>
                        <td>
                            @if (meeting.IsCancelled)
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else if (meeting.MeetingDate > DateTime.Now)
                            {
                                <span class="badge bg-primary">Scheduled</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="MeetingsAddEdit" asp-route-id="@meeting.MeetingID" class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingID" value="@meeting.MeetingID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>



