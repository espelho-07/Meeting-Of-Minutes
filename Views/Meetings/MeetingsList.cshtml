@{
    ViewData["Title"] = "Meetings Management - MOM";
}

@model List<MeetingsModel>

@await Html.PartialAsync("_AlertMessages")
@{
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item active">Meetings</li>
        </ol>
    </nav>
</div>

<div class="mom-page-header">
    <div>
        <h1>Meetings</h1>
        <p class="mom-page-subtitle">Schedule and manage organizational meetings</p>
    </div>

    <div class="mom-toolbar">
        <a asp-action="MeetingsAddEdit" class="btn btn-primary px-4"><i class="bi bi-plus-circle me-2"></i> Schedule Meeting</a>
        <a asp-action="ExportToExcel" class="btn btn-success px-4"><i class="bi bi-file-earmark-excel me-2"></i> Export</a>
    </div>
</div>

<div class="mom-search-card">
    <form class="mom-search-form" asp-action="MeetingsList" asp-controller="Meetings" method="post">
        @Html.AntiForgeryToken()
        <div class="mom-search-input">
            <span><i class="bi bi-search"></i></span>
            <input class="form-control" name="searchtext" value="@ViewBag.searchtext" type="text" placeholder="Search meetings..." />
        </div>
        <button class="btn btn-primary px-4" type="submit">Search</button>
        <a href="@Url.Action("MeetingsList", "Meetings")" class="btn btn-light px-4">Clear</a>
    </form>
    <div class="mom-stat-chip">Total Records: @Model.Count</div>
</div>

<div class="card mom-list-card">
    <div class="card-header">
        <h6><i class="bi bi-calendar-event"></i> Scheduled Meetings</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:44px;"></th>
                    <th class="ps-4">#</th>
                    <th>Date & Time</th>
                    <th>Meeting Type</th>
                    <th>Description</th>
                    <th>Department</th>
                    <th>Venue</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var meeting in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input" /></td>
                        <td class="ps-4">@SerialNumber</td>
                        <td>@meeting.MeetingDate</td>
                        <td>@meeting.MeetingTypeName</td>
                        <td>@meeting.MeetingDescription</td>
                        <td>@meeting.DepartmentName</td>
                        <td>@meeting.MeetingVenueName</td>
                        <td>
                            @if (meeting.IsCancelled)
                            {
                                <span class="badge bg-danger">Cancelled</span>
                            }
                            else if (meeting.MeetingDate > DateTime.Now)
                            {
                                <span class="badge bg-primary">Scheduled</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="MeetingsDetails" asp-route-id="@meeting.MeetingID" class="mom-icon-btn text-primary me-1" title="Manage Meeting"><i class="bi bi-card-list"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingID" value="@meeting.MeetingID" />
                                <button type="submit" class="btn btn-sm btn-link mom-icon-btn text-danger p-0"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>
