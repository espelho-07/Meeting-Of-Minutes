@model MeetingsModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Details - Meeting Of Minutes";
}
<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb flex-nowrap">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item"><a asp-controller="Meetings" asp-action="MeetingsList">Meetings</a></li>
            <li class="breadcrumb-item active">Meeting Details</li>
        </ol>
    </nav>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6><i class="bi bi-calendar-event me-2"></i> Meeting Details</h6>
        <div>
            <a asp-action="MeetingsAddEdit" asp-route-id="@Model.MeetingID" class="btn btn-sm btn-light me-2"><i class="bi bi-pencil"></i> Edit</a>
            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MeetingID" value="@Model.MeetingID" />
                <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i> Delete</button>
            </form>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row gy-3">
            <div class="col-md-6"><strong>Meeting ID:</strong><div class="text-muted">@Model.MeetingID</div></div>
            <div class="col-md-6"><strong>Venue ID:</strong><div class="text-muted">@Model.MeetingVenueID</div></div>
            <div class="col-md-6"><strong>Date & Time:</strong><div class="text-muted">@Model.MeetingDate</div></div>
            <div class="col-md-6"><strong>Status:</strong><div class="text-muted">@(Model.IsCancelled ? "Cancelled" : "Active")</div></div>
            <div class="col-md-6"><strong>Meeting Type ID:</strong><div class="text-muted">@Model.MeetingTypeID</div></div>
            <div class="col-md-6"><strong>Department ID:</strong><div class="text-muted">@Model.DepartmentID</div></div>
            <div class="col-12"><strong>Meeting Description:</strong><div class="border rounded p-3 mt-1 text-muted bg-light">@Model.MeetingDescription</div></div>
        </div>
    </div>
</div>
