@model List<MeetingTypeModel>

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Types - Meeting Of Minutes";
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard"><i class="bi bi-house-door"></i></a></li>
            <li class="breadcrumb-item active">Meeting Types</li>
        </ol>
    </nav>
</div>

<div class="mom-page-header">
    <div>
        <h1>Meeting Types</h1>
        <p class="mom-page-subtitle">Manage different types of meetings in the organization</p>
    </div>
    <div class="mom-toolbar">
        <a asp-action="MeetingsTypeAddEdit" class="btn btn-primary px-4"><i class="bi bi-plus-circle me-1"></i> Add New Type</a>
        <a asp-action="ExportToExcel" class="btn btn-success px-4"><i class="bi bi-file-earmark-excel me-1"></i> Export</a>
    </div>
</div>

<div class="mom-search-card">
    <form class="mom-search-form" asp-action="MeetingsTypeList" asp-controller="MeetingsType" method="post">
        @Html.AntiForgeryToken()
        <div class="mom-search-input">
            <span><i class="bi bi-search"></i></span>
            <input class="form-control" name="searchtext" value="@ViewBag.searchtext" type="text" placeholder="Enter meeting type name..." />
        </div>
        <button class="btn btn-primary px-4" type="submit">Search</button>
        <a href="@Url.Action("MeetingsTypeList", "MeetingsType")" class="btn btn-light px-4">Clear</a>
    </form>
    <div class="mom-stat-chip">Total Records: @Model.Count</div>
</div>

<div class="card mom-list-card">
    <div class="card-header">
        <h6><i class="bi bi-tags"></i> Meeting Types List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:44px;"></th>
                    <th class="ps-4">#</th>
                    <th>Meeting Type Name</th>
                    <th>Remarks</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var meetingType in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input" /></td>
                        <td class="ps-4">@SerialNumber</td>
                        <td class="fw-bold text-primary">@meetingType.MeetingTypeName</td>
                        <td>@meetingType.Remarks</td>
                        <td class="text-center">
                            <a asp-action="MeetingsTypeDetails" asp-route-id="@meetingType.MeetingTypeID" class="mom-icon-btn text-primary me-1"><i class="bi bi-eye"></i></a>
                            <a asp-action="MeetingsTypeAddEdit" asp-route-id="@meetingType.MeetingTypeID" class="mom-icon-btn text-warning me-1"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingTypeID" value="@meetingType.MeetingTypeID" />
                                <button type="submit" class="btn btn-link mom-icon-btn text-danger p-0"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>
