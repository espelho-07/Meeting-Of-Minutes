@model List<MeetingTypeModel>

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Types - Meeting Of Minutes";
    int SerialNumber = 1;
}

<div class="pagetitle mb-4">
    <h1>Meeting Categories</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="DashBoard">Home</a></li>
            <li class="breadcrumb-item active">Meeting Type</li>
        </ol>
    </nav>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted small mb-0">Define meeting categories to structure organizational discussions.</p>

    <a asp-action="MeetingsTypeAddEdit" class="btn btn-primary rounded-pill px-4 shadow-sm" style="background-color:#5a52e0;border:none;">
        <i class="bi bi-tags-fill me-2"></i>
        Add Meeting Type
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px;overflow:hidden;">
    <div class="card-header border-0" style="background:linear-gradient(45deg,#5a52e0,#8965e0);padding:12px 20px;">
        <h6 class="mb-0 fw-bold text-white">Meeting Type List</h6>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase">
                    <th class="ps-4">#</th>
                    <th>Meeting Type Name</th>
                    <th>Remarks</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var meetingType in Model)
                {
                    <tr>
                        <td class="ps-4">@SerialNumber</td>
                        <td class="fw-bold text-primary">@meetingType.MeetingTypeName</td>
                        <td>@meetingType.Remarks</td>
                        <td class="text-center">
                            <a asp-action="MeetingsTypeDetails" asp-route-id="@meetingType.MeetingTypeID" class="text-primary me-2"><i class="bi bi-eye"></i></a>
                            <a asp-action="MeetingsTypeAddEdit" asp-route-id="@meetingType.MeetingTypeID" class="text-warning me-2"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MeetingTypeID" value="@meetingType.MeetingTypeID" />
                                <button type="submit" class="btn btn-link text-danger p-0"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    SerialNumber++;
                }
            </tbody>
        </table>
    </div>
</div>



