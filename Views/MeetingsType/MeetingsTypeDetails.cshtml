@model MeetingTypeModel

@await Html.PartialAsync("_AlertMessages")
@{
    ViewData["Title"] = "Meeting Type Details - MOM";
}

<div class="pagetitle mb-4">
    <h1>Meeting Type Details</h1>
</div>

<div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-header text-white d-flex justify-content-between align-items-center" style="background:linear-gradient(90deg,#6a5ae0,#7f6ae6);border-radius:16px 16px 0 0;">
        <div class="fw-semibold"><i class="bi bi-tags me-2"></i> Meeting Type Information</div>
        <div>
            <a asp-action="MeetingsTypeAddEdit" asp-route-id="@Model.MeetingTypeID" class="btn btn-sm btn-outline-warning me-2"><i class="bi bi-pencil"></i> Edit</a>
            <form asp-action="Delete" method="post" class="d-inline js-delete-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MeetingTypeID" value="@Model.MeetingTypeID" />
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
            </form>
        </div>
    </div>

    <div class="card-body">
        <div class="row gy-4">
            <div class="col-md-6">
                <div class="text-muted small">Meeting Type ID</div>
                <div class="fw-bold fs-6">@Model.MeetingTypeID</div>
            </div>

            <div class="col-md-6">
                <div class="text-muted small">Meeting Type Name</div>
                <span class="badge bg-primary px-3 py-2 fs-6">@Model.MeetingTypeName</span>
            </div>

            <div class="col-12">
                <div class="text-muted small">Remarks</div>
                <div class="border rounded p-3 bg-light">@Model.Remarks</div>
            </div>
        </div>
    </div>
</div>



